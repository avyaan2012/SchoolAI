{
  "version": 2,
  "builds": [
    { "src": "api/generate-quiz.js", "use": "@vercel/node" },
    { "src": "api/generate-review.js", "use": "@vercel/node" },
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/generate-quiz", "dest": "/api/generate-quiz.js" },
    { "src": "/api/generate-review", "dest": "/api/generate-review.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
